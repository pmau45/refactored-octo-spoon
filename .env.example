# ========== REQUIRED ==========

# Site URL (used for metadata canonical URLs and Open Graph)
NEXT_PUBLIC_SITE_URL=https://axiomcanine.dev

# Disable Next.js telemetry during builds
NEXT_TELEMETRY_DISABLED=1

# ========== OPTIONAL ==========

# Google Analytics (optional - uncomment to enable)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email notifications (if using custom email service)
# SENDGRID_API_KEY=your_sendgrid_key_here

# ========== NETLIFY FORMS ==========
# Netlify Forms are automatically handled - no config needed
# Forms are submitted to: https://axiomcanine.dev/
# View submissions in Netlify Dashboard → Forms
